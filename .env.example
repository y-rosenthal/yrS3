# -----------------------------------------------------------------------------
# Supabase (required for auth and, optionally, question storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# When set to "true", middleware skips calling Supabase auth (no session refresh). Use when Supabase is stopped to avoid "fetch failed" errors in the terminal; the app still renders (e.g. login page).
# SUPABASE_SKIP_AUTH_REFRESH=true

# -----------------------------------------------------------------------------
# Questions storage
# -----------------------------------------------------------------------------
# Omit or leave unset for local filesystem; set to "supabase" for Vercel.
# QUESTIONS_STORAGE=supabase

# Root folder for question version folders (default: ./questions).
# QUESTIONS_ROOT=./questions

# Supabase Storage bucket name when QUESTIONS_STORAGE=supabase (default: questions).
# QUESTIONS_BUCKET=questions

# When QUESTIONS_STORAGE=supabase, optional local path to mirror each version for backup (content + db_meta.yaml).
# QUESTIONS_FS_BACKUP_ROOT=./questions-backup

# -----------------------------------------------------------------------------
# Question sync (FS→DB at startup)
# -----------------------------------------------------------------------------
# UUID of the user to assign when importing FS-only question versions into the DB.
# Optional when using the seeded default question owner (after supabase db reset); if set, overrides the default.
# QUESTION_SYNC_OWNER_ID=your-user-uuid

# Service role key so the app can run FS→DB sync before any user logs in. Optional if you only use POST /api/admin/sync-questions while logged in.
# Local: from `supabase status -o env` as SERVICE_ROLE_KEY; you can set either name.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Question sets (FS import only; DB is source of truth)
# -----------------------------------------------------------------------------
# Root folder for set.yaml trees; sync (POST /api/admin/sync-questions) imports into DB. Default: ./question-sets.
# QUESTION_SETS_ROOT=./question-sets

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
# Optional: app URL for redirects (e.g. https://your-app.vercel.app).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# System logging and message store (SPEC 0.0.5)
# -----------------------------------------------------------------------------
# Path for the system log file (append-only, one JSON line per message). Default: logs/app.log (relative to project root).
# LOG_FILE_PATH=logs/app.log

# Maximum number of system messages kept in memory (newest first). When full, oldest are dropped until "Load older" fetches from the log file. Default: 1000.
# SYSTEM_MESSAGE_STORE_SIZE=1000

# Number of older messages to load at a time when the user clicks "Load older" on the /logs page. Default: 100.
# SYSTEM_MESSAGE_LOAD_OLDER_BATCH=100

# Auto-refresh interval for the System log page (/logs) in milliseconds. Default: 4000 (4 seconds). Must be a Next.js public env var so the client can read it.
# NEXT_PUBLIC_LOGS_REFRESH_INTERVAL_MS=4000

# -----------------------------------------------------------------------------
# GitHub OAuth (local Supabase)
# -----------------------------------------------------------------------------
# Set these then run: supabase stop && supabase start. Callback URL = API URL from `supabase status` + /auth/v1/callback
# GITHUB_CLIENT_ID=your-github-oauth-client-id
# GITHUB_SECRET=your-github-oauth-client-secret
